<Window x:Class="CrossETF.Terminal.UiShell.Reference.Views.IndicatorDrawdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="指标回撤中心"
        Width="1500"
        Height="860"
        MinWidth="1180"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="#050B14"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="IndicatorDrawdownWindow_Loaded"
        Closed="IndicatorDrawdownWindow_Closed">
    <Window.Resources>
        <SolidColorBrush x:Key="IndicatorTextBrush" Color="#EAF6FF" />
        <SolidColorBrush x:Key="IndicatorMutedBrush" Color="#91A9BB" />
        <SolidColorBrush x:Key="IndicatorPanelBrush" Color="#071B2A" />
        <SolidColorBrush x:Key="IndicatorPanelAltBrush" Color="#082235" />
        <SolidColorBrush x:Key="IndicatorHeaderBrush" Color="#0B2B42" />
        <SolidColorBrush x:Key="IndicatorBorderBrush" Color="#1F4E68" />
        <SolidColorBrush x:Key="IndicatorSelectedBrush" Color="#123E5A" />
        <SolidColorBrush x:Key="IndicatorNormalBrush" Color="#63D95F" />
        <SolidColorBrush x:Key="IndicatorWarningBrush" Color="#F5A623" />
        <SolidColorBrush x:Key="IndicatorErrorBrush" Color="#FF5D68" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource IndicatorTextBrush}" />
        </Style>

        <Style x:Key="IndicatorScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#355C74" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Margin="2" Background="{TemplateBinding Background}" CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#4A7892" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#5A91AD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IndicatorScrollPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="IndicatorVerticalScrollTemplate" TargetType="ScrollBar">
            <Grid Width="14" Background="#071724">
                <Track x:Name="PART_Track" Orientation="Vertical" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource IndicatorScrollPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinHeight="28" Style="{StaticResource IndicatorScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource IndicatorScrollPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="IndicatorHorizontalScrollTemplate" TargetType="ScrollBar">
            <Grid Height="14" Background="#071724">
                <Track x:Name="PART_Track" Orientation="Horizontal">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource IndicatorScrollPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinWidth="28" Style="{StaticResource IndicatorScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource IndicatorScrollPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="IndicatorScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="14" />
            <Setter Property="MinWidth" Value="14" />
            <Setter Property="Background" Value="#071724" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template" Value="{StaticResource IndicatorVerticalScrollTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="14" />
                    <Setter Property="MinHeight" Value="14" />
                    <Setter Property="Template" Value="{StaticResource IndicatorHorizontalScrollTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IndicatorFilterStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource IndicatorMutedBrush}" />
            <Setter Property="Background" Value="#071724" />
            <Setter Property="BorderBrush" Value="{StaticResource IndicatorBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="FilterBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FilterBorder" Property="Background" Value="#0E334B" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="FilterBorder" Property="Background" Value="#155475" />
                                <Setter TargetName="FilterBorder" Property="BorderBrush" Value="#2C84AA" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IndicatorDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource IndicatorPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource IndicatorTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource IndicatorBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalGridLinesBrush" Value="#12384F" />
            <Setter Property="VerticalGridLinesBrush" Value="#12384F" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="{StaticResource IndicatorPanelBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource IndicatorPanelAltBrush}" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="True" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="RowHeight" Value="27" />
            <Setter Property="MinRowHeight" Value="26" />
            <Setter Property="ColumnHeaderHeight" Value="33" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource IndicatorHeaderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource IndicatorTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource IndicatorBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource IndicatorTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#12384F" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource IndicatorSelectedBrush}" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IndicatorRightTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IndicatorPeriodTextStyle" TargetType="TextBlock" BasedOn="{StaticResource IndicatorRightTextStyle}">
            <Setter Property="ToolTip" Value="{Binding PeriodDataToolTip}" />
        </Style>

        <Style x:Key="IndicatorCenterTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IndicatorStatusTextStyle" TargetType="TextBlock" BasedOn="{StaticResource IndicatorCenterTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource IndicatorMutedBrush}" />
            <Setter Property="ToolTip" Value="{Binding DataStatusDetail}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataStatus}" Value="正常">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorNormalBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="数据不足">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="历史滞后">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="熔断冷却">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="限频">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="实时行情缺失">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="无历史">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="数据损坏">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataStatus}" Value="数据源异常">
                    <Setter Property="Foreground" Value="{StaticResource IndicatorErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IndicatorDetailLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource IndicatorMutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IndicatorDetailValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF6FF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,16,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
    </Window.Resources>

    <Grid Background="#050B14" Margin="18" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="指标回撤中心" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource IndicatorMutedBrush}"
                           Text="真实前复权日线收盘口径；实时 quote 仅用于最新价和当前回撤，不参与历史指标。" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock x:Name="LocalReadStatusText" Text="本地快照 --" HorizontalAlignment="Right" Foreground="{StaticResource IndicatorMutedBrush}" />
                <TextBlock x:Name="HistoryCheckStatusText" Margin="0,4,0,0" Text="历史签名检查 --" HorizontalAlignment="Right" Foreground="{StaticResource IndicatorMutedBrush}" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="7">
            <Border Margin="0,0,8,0" Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5">
                <StackPanel><TextBlock Text="监控标的" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding TotalCount}" FontSize="20" FontWeight="SemiBold" /></StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5">
                <StackPanel><TextBlock Text="正常" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding NormalCount}" FontSize="20" Foreground="{StaticResource IndicatorNormalBrush}" /></StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5">
                <StackPanel><TextBlock Text="数据不足" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding InsufficientCount}" FontSize="20" Foreground="{StaticResource IndicatorWarningBrush}" /></StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5">
                <StackPanel><TextBlock Text="历史滞后" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding StaleCount}" FontSize="20" Foreground="{StaticResource IndicatorWarningBrush}" /></StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5" ToolTip="{Binding AbnormalOrMissingToolTip}">
                <StackPanel><TextBlock Text="异常/缺失" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding AbnormalOrMissingCount}" FontSize="20" Foreground="{StaticResource IndicatorErrorBrush}" /></StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5">
                <StackPanel><TextBlock Text="当前最深回撤" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding DeepestCurrentText}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /></StackPanel>
            </Border>
            <Border Padding="12,9" Background="#071B2A" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="5">
                <StackPanel><TextBlock Text="历史最深回撤" Foreground="{StaticResource IndicatorMutedBrush}" /><TextBlock Text="{Binding DeepestMaximumText}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /></StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="全部" Tag="全部" IsChecked="True" Style="{StaticResource IndicatorFilterStyle}" Checked="FilterButton_Checked" />
                <RadioButton Content="指数" Tag="指数" Style="{StaticResource IndicatorFilterStyle}" Checked="FilterButton_Checked" />
                <RadioButton Content="场内 ETF" Tag="场内 ETF" Style="{StaticResource IndicatorFilterStyle}" Checked="FilterButton_Checked" />
            </StackPanel>
            <Border Grid.Column="1" Width="310" Height="32" Margin="12,0,0,0" Background="#071724" BorderBrush="#1F4E68" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <TextBox x:Name="SearchTextBox"
                             Margin="10,0"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             Foreground="#EAF6FF"
                             BorderThickness="0"
                             CaretBrush="#EAF6FF"
                             TextChanged="SearchTextBox_TextChanged" />
                    <TextBlock Margin="11,0" VerticalAlignment="Center" Foreground="#66859A" Text="搜索代码、名称、策略、来源或状态" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            <TextBlock x:Name="FilteredCountText" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource IndicatorMutedBrush}" Text="当前显示 0 / 0" />
        </Grid>

        <DataGrid x:Name="DrawdownGrid"
                  Grid.Row="6"
                  Style="{StaticResource IndicatorDataGridStyle}"
                  SelectionChanged="DrawdownGrid_SelectionChanged">
            <DataGrid.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource IndicatorScrollBarStyle}" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="82" ElementStyle="{StaticResource IndicatorCenterTextStyle}" />
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="220" />
                <DataGridTextColumn Header="代码" Binding="{Binding Code}" Width="112" ElementStyle="{StaticResource IndicatorCenterTextStyle}" />
                <DataGridTextColumn Header="关联策略" Binding="{Binding StrategyCodes}" Width="160" />
                <DataGridTextColumn Header="最新价" Binding="{Binding LatestPriceText}" SortMemberPath="LatestPrice" Width="100" ElementStyle="{StaticResource IndicatorRightTextStyle}" />
                <DataGridTextColumn Header="历史最高收盘" Binding="{Binding HistoricalMaximumCloseText}" SortMemberPath="HistoricalMaximumClose" Width="122" ElementStyle="{StaticResource IndicatorRightTextStyle}" />
                <DataGridTextColumn Header="高点日期" Binding="{Binding HistoricalMaximumDateText}" SortMemberPath="HistoricalMaximumDate" Width="105" ElementStyle="{StaticResource IndicatorCenterTextStyle}" />
                <DataGridTextColumn Header="当前回撤" Binding="{Binding CurrentDrawdownText}" SortMemberPath="CurrentDrawdown" Width="125" ElementStyle="{StaticResource IndicatorRightTextStyle}" />
                <DataGridTextColumn Header="20 日回撤" Binding="{Binding Drawdown20Text}" SortMemberPath="Drawdown20" Width="105" ElementStyle="{StaticResource IndicatorPeriodTextStyle}" />
                <DataGridTextColumn Header="60 日回撤" Binding="{Binding Drawdown60Text}" SortMemberPath="Drawdown60" Width="105" ElementStyle="{StaticResource IndicatorPeriodTextStyle}" />
                <DataGridTextColumn Header="120 日回撤" Binding="{Binding Drawdown120Text}" SortMemberPath="Drawdown120" Width="112" ElementStyle="{StaticResource IndicatorPeriodTextStyle}" />
                <DataGridTextColumn Header="252 日回撤" Binding="{Binding Drawdown252Text}" SortMemberPath="Drawdown252" Width="112" ElementStyle="{StaticResource IndicatorPeriodTextStyle}" />
                <DataGridTextColumn Header="年初至今回撤" Binding="{Binding YearToDateDrawdownText}" SortMemberPath="YearToDateDrawdown" Width="122" ElementStyle="{StaticResource IndicatorPeriodTextStyle}" />
                <DataGridTextColumn Header="历史最大回撤" Binding="{Binding MaximumDrawdownText}" SortMemberPath="MaximumDrawdown" Width="122" ElementStyle="{StaticResource IndicatorRightTextStyle}" />
                <DataGridTextColumn Header="最大回撤区间" Binding="{Binding MaximumDrawdownIntervalText}" Width="190" ElementStyle="{StaticResource IndicatorCenterTextStyle}" />
                <DataGridTextColumn Header="历史数据" Binding="{Binding HistoricalDataText}" Width="235" />
                <DataGridTextColumn Header="数据来源" Binding="{Binding DataSourceText}" Width="245" />
                <DataGridTextColumn Header="数据状态" Binding="{Binding DataStatus}" Width="112" ElementStyle="{StaticResource IndicatorStatusTextStyle}" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="8"
                Height="104"
                MinHeight="90"
                MaxHeight="120"
                Padding="10"
                Background="#071825"
                BorderBrush="#163A50"
                BorderThickness="1"
                CornerRadius="4">
            <Grid x:Name="SelectedDetailPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="选中标的：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedInstrumentText" Grid.Column="1" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="2" Text="分类：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedCategoryText" Grid.Column="3" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="4" Text="关联策略：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedStrategyText" Grid.Column="5" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="195" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="历史来源：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedHistorySourceText" Grid.Column="1" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="2" Text="实时来源：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedQuoteSourceText" Grid.Column="3" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="4" Text="历史区间：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedHistoryRangeText" Grid.Column="5" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="6" Text="数据点数：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedHistoryPointCountText" Grid.Column="7" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="8" Text="历史最高：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedHistoricalHighText" Grid.Column="9" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="85" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="当前回撤：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedCurrentDrawdownText" Grid.Column="1" Text="--" Foreground="#FF8A70" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="2" Text="历史最大回撤：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedMaximumDrawdownText" Grid.Column="3" Text="--" Foreground="#FF8A70" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="4" Text="最大回撤区间：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedMaximumIntervalText" Grid.Column="5" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="6" Text="状态：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedStatusText" Grid.Column="7" Text="--" Style="{StaticResource IndicatorDetailValueStyle}" />
                    <TextBlock Grid.Column="8" Text="状态说明：" Style="{StaticResource IndicatorDetailLabelStyle}" />
                    <TextBlock x:Name="SelectedStatusDetailText" Grid.Column="9" Text="请选择一行查看详情" Style="{StaticResource IndicatorDetailValueStyle}" />
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="10"
                   MinHeight="28"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource IndicatorMutedBrush}"
                   FontSize="12.5"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
