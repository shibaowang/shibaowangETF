<Window x:Class="CrossETF.Terminal.UiShell.Reference.Views.SecurityChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#050B14"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="ChartTextBrush" Color="#EAF6FF" />
        <SolidColorBrush x:Key="ChartMutedBrush" Color="#9FB7C8" />
        <SolidColorBrush x:Key="ChartPanelBrush" Color="#071B2A" />
        <SolidColorBrush x:Key="ChartHeaderBrush" Color="#081D2C" />
        <SolidColorBrush x:Key="ChartBorderBrush" Color="#1F4E68" />
        <SolidColorBrush x:Key="ChartHoverBrush" Color="#123A55" />
        <SolidColorBrush x:Key="ChartSelectedBrush" Color="#1A5D80" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ChartTextBrush}" />
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="#071724" />
            <Setter Property="Foreground" Value="{StaticResource ChartTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChartBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MaxWidth" Value="460" />
            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ChartButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource ChartTextBrush}" />
            <Setter Property="Background" Value="#082235" />
            <Setter Property="BorderBrush" Value="{StaticResource ChartBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ChartHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ChartSelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F8798" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ChartWindowRootBorder"
            BorderBrush="#17344B"
            BorderThickness="1"
            Background="#050B14"
            SnapsToDevicePixels="True"
            ClipToBounds="True">
        <Grid x:Name="ChartWindowRootGrid"
              Background="#050B14"
              SnapsToDevicePixels="True"
              ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="86" />
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="170" />
                <RowDefinition Height="34" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#061522"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="42" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="WindowTitleText"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="-"
                        Style="{StaticResource ChartButtonStyle}"
                        Padding="0"
                        Click="MinimizeButton_Click" />
                <Button Grid.Column="2"
                        Content="×"
                        Style="{StaticResource ChartButtonStyle}"
                        Padding="0"
                        Click="CloseButton_Click" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="14,12,14,6"
                    Padding="14,10"
                    Background="{StaticResource ChartHeaderBrush}"
                    BorderBrush="{StaticResource ChartBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="1.6*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="SecurityNameText" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="SecurityCodeText" Margin="0,7,0,0" Foreground="{StaticResource ChartMutedBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="现价" Foreground="{StaticResource ChartMutedBrush}" />
                        <TextBlock x:Name="PriceText" Margin="0,7,0,0" FontSize="18" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="涨跌" Foreground="{StaticResource ChartMutedBrush}" />
                        <TextBlock x:Name="ChangeText" Margin="0,7,0,0" FontSize="18" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="溢价率" Foreground="{StaticResource ChartMutedBrush}" />
                        <TextBlock x:Name="PremiumText" Margin="0,7,0,0" FontSize="18" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="数据状态" Foreground="{StaticResource ChartMutedBrush}" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,7,0,0"
                                   MaxWidth="210"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ShowDuration="12000" />
                    </StackPanel>
                    <StackPanel Grid.Column="5">
                        <TextBlock Text="更新时间" Foreground="{StaticResource ChartMutedBrush}" />
                        <TextBlock x:Name="UpdatedText" Margin="0,7,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="14,0,14,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="IntradayButton" Content="分时" Style="{StaticResource ChartButtonStyle}" Margin="0,0,8,0" Click="PeriodButton_Click" />
                    <Button x:Name="DailyButton" Content="日K" Style="{StaticResource ChartButtonStyle}" Margin="0,0,8,0" Click="PeriodButton_Click" />
                    <Button x:Name="WeeklyButton" Content="周K" Style="{StaticResource ChartButtonStyle}" Margin="0,0,8,0" Click="PeriodButton_Click" />
                    <Button x:Name="MonthlyButton" Content="月K" Style="{StaticResource ChartButtonStyle}" Click="PeriodButton_Click" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button x:Name="Ma5Button" Content="MA5" Style="{StaticResource ChartButtonStyle}" Padding="9,7" Margin="8,0,4,0" Click="MovingAverageButton_Click" />
                    <Button x:Name="Ma10Button" Content="MA10" Style="{StaticResource ChartButtonStyle}" Padding="9,7" Margin="0,0,4,0" Click="MovingAverageButton_Click" />
                    <Button x:Name="Ma20Button" Content="MA20" Style="{StaticResource ChartButtonStyle}" Padding="9,7" Margin="0,0,4,0" Click="MovingAverageButton_Click" />
                    <Button x:Name="Ma60Button" Content="MA60" Style="{StaticResource ChartButtonStyle}" Padding="9,7" Margin="0,0,8,0" Click="MovingAverageButton_Click" />
                    <Button x:Name="ResetViewButton" Content="复位" Style="{StaticResource ChartButtonStyle}" Padding="10,7" Click="ResetViewButton_Click" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="VolumeButton" Content="成交量" Style="{StaticResource ChartButtonStyle}" Margin="0,0,8,0" Click="SubPanelButton_Click" />
                    <Button x:Name="MacdButton" Content="MACD" Style="{StaticResource ChartButtonStyle}" Click="SubPanelButton_Click" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="3"
                    Margin="14,0,14,8"
                    Background="{StaticResource ChartPanelBrush}"
                    BorderBrush="{StaticResource ChartBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True">
                <Grid Background="{StaticResource ChartPanelBrush}"
                      ClipToBounds="True">
                    <Canvas x:Name="MainChartCanvas"
                            Background="{StaticResource ChartPanelBrush}"
                            ClipToBounds="True"
                            SnapsToDevicePixels="True"
                            Focusable="True"
                            SizeChanged="ChartCanvas_SizeChanged"
                            MouseWheel="MainChartCanvas_MouseWheel"
                            MouseLeftButtonDown="MainChartCanvas_MouseLeftButtonDown"
                            MouseMove="MainChartCanvas_MouseMove"
                            MouseLeftButtonUp="MainChartCanvas_MouseLeftButtonUp"
                            MouseLeave="MainChartCanvas_MouseLeave"
                            LostMouseCapture="MainChartCanvas_LostMouseCapture" />
                    <TextBlock x:Name="MovingAverageLegendText"
                               Margin="50,4,16,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Foreground="{StaticResource ChartTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               IsHitTestVisible="False" />
                    <Border x:Name="CrosshairInfoBorder"
                            Margin="50,25,16,0"
                            Padding="7,4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            MaxWidth="840"
                            Background="#E6071724"
                            BorderBrush="{StaticResource ChartBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="CrosshairInfoText"
                                   Foreground="{StaticResource ChartTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Margin="14,0,14,8"
                    Background="{StaticResource ChartPanelBrush}"
                    BorderBrush="{StaticResource ChartBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True">
                <Canvas x:Name="SubChartCanvas"
                        Background="{StaticResource ChartPanelBrush}"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"
                        SizeChanged="ChartCanvas_SizeChanged" />
            </Border>

            <TextBlock Grid.Row="5"
                       x:Name="FooterStatusText"
                       Margin="18,0,18,0"
                       Foreground="{StaticResource ChartMutedBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</Window>
