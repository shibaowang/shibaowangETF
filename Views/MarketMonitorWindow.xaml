<Window x:Class="CrossETF.Terminal.UiShell.Reference.Views.MarketMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="行情监控中心"
        Width="1500"
        Height="860"
        MinWidth="1180"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="#050B14"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="MarketMonitorWindow_Loaded"
        Closed="MarketMonitorWindow_Closed">
    <Window.Resources>
        <SolidColorBrush x:Key="MonitorTextBrush" Color="#EAF6FF" />
        <SolidColorBrush x:Key="MonitorMutedBrush" Color="#91A9BB" />
        <SolidColorBrush x:Key="MonitorPanelBrush" Color="#071B2A" />
        <SolidColorBrush x:Key="MonitorPanelAltBrush" Color="#082235" />
        <SolidColorBrush x:Key="MonitorHeaderBrush" Color="#0B2B42" />
        <SolidColorBrush x:Key="MonitorBorderBrush" Color="#1F4E68" />
        <SolidColorBrush x:Key="MonitorHoverBrush" Color="#0E334B" />
        <SolidColorBrush x:Key="MonitorSelectedBrush" Color="#123E5A" />
        <SolidColorBrush x:Key="MonitorUpBrush" Color="#FF4D57" />
        <SolidColorBrush x:Key="MonitorDownBrush" Color="#84CC16" />
        <SolidColorBrush x:Key="MonitorNormalBrush" Color="#63D95F" />
        <SolidColorBrush x:Key="MonitorWarningBrush" Color="#F5A623" />
        <SolidColorBrush x:Key="MonitorErrorBrush" Color="#FF5D68" />

        <Style x:Key="MarketMonitorScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#355C74" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#4A7892" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#5A91AD" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MarketMonitorScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#0A1C2A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="LineButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LineButtonBorder" Property="Background" Value="#12344A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="LineButtonBorder" Property="Background" Value="#19506E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LineButtonBorder" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MarketMonitorScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="PageButtonBorder"
                                Background="{TemplateBinding Background}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PageButtonBorder" Property="Background" Value="#0A2233" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PageButtonBorder" Property="Background" Value="#10364D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="MarketMonitorVerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="15" Background="#071724" SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="15" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="15" />
                </Grid.RowDefinitions>
                <RepeatButton Grid.Row="0"
                              Command="{x:Static ScrollBar.LineUpCommand}"
                              CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                              Style="{StaticResource MarketMonitorScrollBarLineButtonStyle}">
                    <Path Width="7" Height="4" Fill="#8EADC0" Stretch="Fill" Data="M 0 4 L 3.5 0 L 7 4 Z" />
                </RepeatButton>
                <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource MarketMonitorScrollBarPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinHeight="28" Style="{StaticResource MarketMonitorScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource MarketMonitorScrollBarPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="2"
                              Command="{x:Static ScrollBar.LineDownCommand}"
                              CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                              Style="{StaticResource MarketMonitorScrollBarLineButtonStyle}">
                    <Path Width="7" Height="4" Fill="#8EADC0" Stretch="Fill" Data="M 0 0 L 3.5 4 L 7 0 Z" />
                </RepeatButton>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="MarketMonitorHorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="15" Background="#071724" SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                </Grid.ColumnDefinitions>
                <RepeatButton Grid.Column="0"
                              Command="{x:Static ScrollBar.LineLeftCommand}"
                              CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                              Style="{StaticResource MarketMonitorScrollBarLineButtonStyle}">
                    <Path Width="4" Height="7" Fill="#8EADC0" Stretch="Fill" Data="M 4 0 L 0 3.5 L 4 7 Z" />
                </RepeatButton>
                <Track x:Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource MarketMonitorScrollBarPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinWidth="28" Style="{StaticResource MarketMonitorScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource MarketMonitorScrollBarPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="2"
                              Command="{x:Static ScrollBar.LineRightCommand}"
                              CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                              Style="{StaticResource MarketMonitorScrollBarLineButtonStyle}">
                    <Path Width="4" Height="7" Fill="#8EADC0" Stretch="Fill" Data="M 0 0 L 4 3.5 L 0 7 Z" />
                </RepeatButton>
            </Grid>
        </ControlTemplate>

        <Style x:Key="MarketMonitorScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="15" />
            <Setter Property="MinWidth" Value="15" />
            <Setter Property="Background" Value="#071724" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource MarketMonitorVerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="15" />
                    <Setter Property="MinHeight" Value="15" />
                    <Setter Property="Template" Value="{StaticResource MarketMonitorHorizontalScrollBarTemplate}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MonitorTextBrush}" />
        </Style>

        <Style x:Key="MonitorFilterStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource MonitorMutedBrush}" />
            <Setter Property="Background" Value="#071724" />
            <Setter Property="BorderBrush" Value="{StaticResource MonitorBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="FilterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FilterBorder" Property="Background" Value="{StaticResource MonitorHoverBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="FilterBorder" Property="Background" Value="{StaticResource MonitorSelectedBrush}" />
                                <Setter TargetName="FilterBorder" Property="BorderBrush" Value="#3D88B0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonitorSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#071724" />
            <Setter Property="Foreground" Value="{StaticResource MonitorTextBrush}" />
            <Setter Property="CaretBrush" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource MonitorBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="#39759A" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="#2F9DDB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SearchBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MarketMonitorDataGridBaseStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource MonitorPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MonitorTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MonitorBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#15384F" />
            <Setter Property="VerticalGridLinesBrush" Value="#15384F" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="{StaticResource MonitorPanelBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource MonitorPanelAltBrush}" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="MarketMonitorQuoteGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource MarketMonitorDataGridBaseStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ColumnHeaderHeight" Value="32" />
            <Setter Property="RowHeight" Value="26" />
            <Setter Property="MinRowHeight" Value="25" />
        </Style>

        <Style x:Key="MarketMonitorSourceGridStyle"
               TargetType="DataGrid"
               BasedOn="{StaticResource MarketMonitorDataGridBaseStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ColumnHeaderHeight" Value="30" />
            <Setter Property="RowHeight" Value="26" />
            <Setter Property="MinRowHeight" Value="25" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource MonitorHeaderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MonitorTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MonitorBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource MonitorTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#12384F" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource MonitorSelectedBrush}" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonitorTrendTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MonitorMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TrendStatus}" Value="上涨">
                    <Setter Property="Foreground" Value="{StaticResource MonitorUpBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TrendStatus}" Value="下跌">
                    <Setter Property="Foreground" Value="{StaticResource MonitorDownBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TrendStatus}" Value="持平">
                    <Setter Property="Foreground" Value="{StaticResource MonitorTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonitorFreshnessTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MonitorMutedBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding FreshnessStatus}" Value="正常">
                    <Setter Property="Foreground" Value="{StaticResource MonitorNormalBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FreshnessStatus}" Value="延迟">
                    <Setter Property="Foreground" Value="{StaticResource MonitorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FreshnessStatus}" Value="过期">
                    <Setter Property="Foreground" Value="{StaticResource MonitorErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FreshnessStatus}" Value="时间无效">
                    <Setter Property="Foreground" Value="{StaticResource MonitorErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonitorSourceStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MonitorMutedBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="正常">
                    <Setter Property="Foreground" Value="{StaticResource MonitorNormalBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="限频">
                    <Setter Property="Foreground" Value="{StaticResource MonitorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="熔断冷却">
                    <Setter Property="Foreground" Value="{StaticResource MonitorWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="异常">
                    <Setter Property="Foreground" Value="{StaticResource MonitorErrorBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16" Background="#050B14" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="158" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="行情监控中心" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="监控指数、汇率、场内ETF、场外基金及本地行情源运行状态"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource MonitorMutedBrush}"
                           FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock x:Name="LocalReadStatusText"
                           Text="等待读取本地行情"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource MonitorMutedBrush}" />
                <TextBlock x:Name="FilteredCountText"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource MonitorMutedBrush}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" MinHeight="72" Background="{StaticResource MonitorPanelBrush}" BorderBrush="{StaticResource MonitorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="监控标的" FontSize="13" Foreground="{StaticResource MonitorMutedBrush}" />
                    <TextBlock Text="{Binding TotalCount}" FontSize="21" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" MinHeight="72" Background="{StaticResource MonitorPanelBrush}" BorderBrush="{StaticResource MonitorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="缓存正常" FontSize="13" Foreground="{StaticResource MonitorMutedBrush}" />
                    <TextBlock Text="{Binding NormalCount}" FontSize="21" FontWeight="SemiBold" Margin="0,4,0,0" Foreground="{StaticResource MonitorNormalBrush}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" MinHeight="72" Background="{StaticResource MonitorPanelBrush}" BorderBrush="{StaticResource MonitorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="缓存延迟" FontSize="13" Foreground="{StaticResource MonitorMutedBrush}" />
                    <TextBlock Text="{Binding DelayedCount}" FontSize="21" FontWeight="SemiBold" Margin="0,4,0,0" Foreground="{StaticResource MonitorWarningBrush}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="6" MinHeight="72" Background="{StaticResource MonitorPanelBrush}" BorderBrush="{StaticResource MonitorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="过期 / 无数据" FontSize="13" Foreground="{StaticResource MonitorMutedBrush}" />
                    <TextBlock Text="{Binding ExpiredOrMissingCount}" FontSize="21" FontWeight="SemiBold" Margin="0,4,0,0" Foreground="{StaticResource MonitorErrorBrush}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="8" MinHeight="72" Background="{StaticResource MonitorPanelBrush}" BorderBrush="{StaticResource MonitorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="数据源状态" FontSize="13" Foreground="{StaticResource MonitorMutedBrush}" />
                    <TextBlock Text="{Binding SourceSummaryText}" FontSize="19" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="AllFilterButton" Content="全部" Tag="全部" GroupName="MarketTypeFilter" IsChecked="True" Style="{StaticResource MonitorFilterStyle}" Checked="FilterButton_Checked" />
                <RadioButton Content="指数/汇率" Tag="指数/汇率" GroupName="MarketTypeFilter" Style="{StaticResource MonitorFilterStyle}" Checked="FilterButton_Checked" />
                <RadioButton Content="场内ETF" Tag="场内ETF" GroupName="MarketTypeFilter" Style="{StaticResource MonitorFilterStyle}" Checked="FilterButton_Checked" />
                <RadioButton Content="场外基金" Tag="场外基金" GroupName="MarketTypeFilter" Style="{StaticResource MonitorFilterStyle}" Checked="FilterButton_Checked" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                <TextBlock Text="搜索" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource MonitorMutedBrush}" />
                <TextBox x:Name="SearchTextBox"
                         Width="250"
                         Style="{StaticResource MonitorSearchTextBoxStyle}"
                         ToolTip="按代码、名称、策略代码或数据源搜索"
                         TextChanged="SearchTextBox_TextChanged" />
            </StackPanel>
        </Grid>

        <DataGrid x:Name="QuoteGrid"
                  Grid.Row="6"
                  Style="{StaticResource MarketMonitorQuoteGridStyle}"
                  ItemsSource="{Binding QuoteRows}"
                  FrozenColumnCount="3">
            <DataGrid.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource MarketMonitorScrollBarStyle}" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="88" />
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" MinWidth="210" />
                <DataGridTextColumn Header="代码" Binding="{Binding Code}" Width="105" />
                <DataGridTemplateColumn Header="最新价 / 净值" Width="108">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding PriceText}" Style="{StaticResource MonitorTrendTextStyle}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="涨跌额" Width="92">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding ChangeValueText}" Style="{StaticResource MonitorTrendTextStyle}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="涨跌幅" Width="92">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding ChangePercentText}" Style="{StaticResource MonitorTrendTextStyle}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="昨收" Binding="{Binding LastCloseText}" Width="95" />
                <DataGridTextColumn Header="开盘" Binding="{Binding OpenText}" Width="95" />
                <DataGridTextColumn Header="最高" Binding="{Binding HighText}" Width="95" />
                <DataGridTextColumn Header="最低" Binding="{Binding LowText}" Width="95" />
                <DataGridTemplateColumn Header="成交量" Width="105">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding VolumeText}" ToolTip="{Binding VolumeFullText}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="成交额" Width="105">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding AmountText}" ToolTip="{Binding AmountFullText}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="IOPV" Binding="{Binding IopvText}" Width="95" />
                <DataGridTemplateColumn Header="数据来源" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding SourceName}" ToolTip="{Binding Source}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="行情时间" Binding="{Binding QuoteTime}" Width="154" />
                <DataGridTextColumn Header="本地接收时间" Binding="{Binding ReceivedAt}" Width="154" />
                <DataGridTemplateColumn Header="缓存状态" Width="92">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding FreshnessStatus}" Style="{StaticResource MonitorFreshnessTextStyle}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="缓存年龄" Binding="{Binding CacheAge}" Width="95" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="8" Text="数据源状态" FontSize="16" FontWeight="SemiBold" />

        <DataGrid x:Name="SourceStatusGrid"
                  Grid.Row="9"
                  MinHeight="150"
                  Style="{StaticResource MarketMonitorSourceGridStyle}"
                  ItemsSource="{Binding SourceRows}"
                  Margin="0,7,0,0">
            <DataGrid.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource MarketMonitorScrollBarStyle}" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="数据源" Binding="{Binding SourceName}" Width="170" />
                <DataGridTemplateColumn Header="当前状态" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding Status}" Style="{StaticResource MonitorSourceStatusTextStyle}" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="最近成功" Binding="{Binding LastSuccessAt}" Width="155" />
                <DataGridTextColumn Header="最近失败" Binding="{Binding LastFailureAt}" Width="155" />
                <DataGridTextColumn Header="连续失败次数" Binding="{Binding FailureCountText}" Width="120" />
                <DataGridTextColumn Header="冷却至" Binding="{Binding CooldownUntil}" Width="155" />
                <DataGridTemplateColumn Header="最近错误" Width="*" MinWidth="240">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><TextBlock Text="{Binding LastError}" ToolTip="{Binding LastError}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAt}" Width="155" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
