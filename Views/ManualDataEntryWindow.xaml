<Window x:Class="CrossETF.Terminal.UiShell.Reference.Views.ManualDataEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="本地数据手动录入"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#050B14"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="EntryTextBrush" Color="#EAF6FF" />
        <SolidColorBrush x:Key="EntryMutedBrush" Color="#9FB7C8" />
        <SolidColorBrush x:Key="EntryDisabledBrush" Color="#7E98AA" />
        <SolidColorBrush x:Key="EntryBackgroundBrush" Color="#061927" />
        <SolidColorBrush x:Key="EntryPanelBrush" Color="#082235" />
        <SolidColorBrush x:Key="EntryGridBrush" Color="#071B2A" />
        <SolidColorBrush x:Key="EntryGridAltBrush" Color="#082235" />
        <SolidColorBrush x:Key="EntryHeaderBrush" Color="#0B2B42" />
        <SolidColorBrush x:Key="EntryHoverBrush" Color="#0E334B" />
        <SolidColorBrush x:Key="EntrySelectedBrush" Color="#123E5A" />
        <SolidColorBrush x:Key="EntryFieldBrush" Color="#071B2A" />
        <SolidColorBrush x:Key="EntryBorderBrush" Color="#1F4E68" />
        <SolidColorBrush x:Key="EntryButtonBorderBrush" Color="#2A6F93" />
        <SolidColorBrush x:Key="EntryAccentBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="EntryComboPopupBrush" Color="#071724" />
        <SolidColorBrush x:Key="EntryComboHoverBrush" Color="#123A55" />
        <SolidColorBrush x:Key="EntryComboSelectedBrush" Color="#1A5D80" />
        <SolidColorBrush x:Key="EntryComboDisabledBrush" Color="#6F8798" />
        <SolidColorBrush x:Key="EntryScrollBarBackgroundBrush" Color="#071724" />
        <SolidColorBrush x:Key="EntryScrollBarTrackBrush" Color="#0B2233" />
        <SolidColorBrush x:Key="EntryScrollBarThumbBrush" Color="#2A6688" />
        <SolidColorBrush x:Key="EntryScrollBarThumbHoverBrush" Color="#3D88B0" />
        <SolidColorBrush x:Key="EntryScrollBarThumbPressedBrush" Color="#52A8D0" />
        <SolidColorBrush x:Key="EntryScrollBarArrowBrush" Color="#CFEFFF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
        </Style>

        <Style x:Key="EntryScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{StaticResource EntryScrollBarArrowBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryScrollBarTrackBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource EntryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource EntrySelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource EntryDisabledBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource EntryScrollBarBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EntryScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="{StaticResource EntryScrollBarTrackBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EntryScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{StaticResource EntryScrollBarThumbBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource EntryScrollBarThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource EntryScrollBarThumbPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="{StaticResource EntryGridBrush}" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource EntryScrollBarBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EntryScrollBarArrowBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="VerticalRoot"
                              Width="{TemplateBinding Width}"
                              Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="18" />
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0"
                                          Content="▲"
                                          FontSize="8"
                                          Style="{StaticResource EntryScrollBarButtonStyle}"
                                          Command="{x:Static ScrollBar.LineUpCommand}"
                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                            <Border Grid.Row="1"
                                    Background="{StaticResource EntryScrollBarTrackBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1,0">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource EntryScrollBarPageButtonStyle}"
                                                      Command="{x:Static ScrollBar.PageUpCommand}"
                                                      CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Margin="2"
                                               MinHeight="26"
                                               Style="{StaticResource EntryScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource EntryScrollBarPageButtonStyle}"
                                                      Command="{x:Static ScrollBar.PageDownCommand}"
                                                      CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                            <RepeatButton Grid.Row="2"
                                          Content="▼"
                                          FontSize="8"
                                          Style="{StaticResource EntryScrollBarButtonStyle}"
                                          Command="{x:Static ScrollBar.LineDownCommand}"
                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Height="{TemplateBinding Height}"
                                      Background="{TemplateBinding Background}"
                                      SnapsToDevicePixels="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton Grid.Column="0"
                                                  Content="◀"
                                                  FontSize="8"
                                                  Style="{StaticResource EntryScrollBarButtonStyle}"
                                                  Command="{x:Static ScrollBar.LineLeftCommand}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                                    <Border Grid.Column="1"
                                            Background="{StaticResource EntryScrollBarTrackBrush}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="0,1">
                                        <Track x:Name="PART_Track"
                                               IsDirectionReversed="False">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource EntryScrollBarPageButtonStyle}"
                                                              Command="{x:Static ScrollBar.PageLeftCommand}"
                                                              CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Margin="2"
                                                       MinWidth="34"
                                                       Style="{StaticResource EntryScrollBarThumbStyle}" />
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource EntryScrollBarPageButtonStyle}"
                                                              Command="{x:Static ScrollBar.PageRightCommand}"
                                                              CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Border>
                                    <RepeatButton Grid.Column="2"
                                                  Content="▶"
                                                  FontSize="8"
                                                  Style="{StaticResource EntryScrollBarButtonStyle}"
                                                  Command="{x:Static ScrollBar.LineRightCommand}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource EntryHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource EntrySelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#071B2A" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1A3D52" />
                                <Setter Property="Foreground" Value="{StaticResource EntryDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EntryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}" />

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryFieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource EntrySelectedBrush}" />
            <Setter Property="SelectionTextBrush" Value="#FFFFFF" />
            <Setter Property="CaretBrush" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="#061522" />
                                <Setter Property="Foreground" Value="{StaticResource EntryDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EntryDataGridTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="EntryDataGridEditingTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="Auto" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryFieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="#FFFFFF" />
            <Setter Property="SelectionBrush" Value="{StaticResource EntryComboSelectedBrush}" />
            <Setter Property="SelectionTextBrush" Value="#FFFFFF" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryFieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <Grid>
                                                <ContentPresenter Margin="8,0,30,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="{StaticResource EntryTextBrush}" />
                                                <Path HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"
                                                      Fill="{StaticResource EntryTextBrush}"
                                                      Data="M 0 0 L 8 0 L 4 5 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource EntryHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="8,0,30,0"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{StaticResource EntryComboPopupBrush}"
                                        BorderBrush="{StaticResource EntryButtonBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer Background="{StaticResource EntryComboPopupBrush}"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource EntryDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryComboPopupBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource EntryComboHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource EntryComboHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource EntryComboSelectedBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource EntryComboPopupBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryComboDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EntryComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource {x:Type ComboBoxItem}}" />
        </Style>

        <Style x:Key="TradeLogComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}" />

        <Style x:Key="TradeLogComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource EntryComboBoxStyle}">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryFieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource TradeLogComboBoxItemStyle}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBoxBorder"
                                    Width="16"
                                    Height="16"
                                    Background="{StaticResource EntryFieldBrush}"
                                    BorderBrush="{StaticResource EntryBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Path x:Name="CheckMark"
                                      Data="M 3 8 L 7 12 L 13 4"
                                      Stroke="{StaticResource EntryTextBrush}"
                                      StrokeThickness="2"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{StaticResource EntrySelectedBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource EntryDisabledBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#1A3D52" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryFieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryHeaderBrush}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource EntrySelectedBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource EntryMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource EntryHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource EntryGridBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource EntryGridBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource EntryGridAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource EntryHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource EntryGridBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource EntryGridAltBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource EntryHoverBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource EntrySelectedBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource EntryBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="CellBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CellBorder" Property="Background" Value="{StaticResource EntrySelectedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource EntryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="CellBorder" Property="BorderBrush" Value="{StaticResource EntryButtonBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18" Background="#050B14">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
            <RowDefinition Height="42" />
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="WindowTitleText" Text="本地数据手动录入" FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Name="DatabasePathText" Margin="0,8,0,0" FontSize="13" Foreground="{StaticResource EntryMutedBrush}" />
            </StackPanel>
        </Grid>

        <TabControl x:Name="EntryTabs" Grid.Row="1">
            <TabItem x:Name="StrategyTabItem" Header="策略配置">
                <Grid x:Name="StrategyTabRoot" Background="#050B14" />
            </TabItem>
            <TabItem x:Name="AccountTabItem" Header="账户状态">
                <Grid x:Name="AccountTabRoot" Background="#050B14" />
            </TabItem>
            <TabItem x:Name="PositionTabItem" Header="持仓">
                <Grid x:Name="PositionTabRoot" Background="#050B14" />
            </TabItem>
            <TabItem x:Name="OtcTabItem" Header="OTCMap">
                <Grid x:Name="OtcTabRoot" Background="#050B14" />
            </TabItem>
            <TabItem x:Name="BasePositionSettingsTabItem" Header="底仓基准设置">
                <Grid x:Name="BasePositionSettingsTabRoot" Background="#050B14" />
            </TabItem>
            <TabItem x:Name="TradeLogTabItem" Header="TradeLog">
                <Grid x:Name="TradeLogTabRoot" Background="#050B14" />
            </TabItem>
            <TabItem x:Name="SystemMaintenanceTabItem" Header="系统维护">
                <Grid x:Name="SystemMaintenanceTabRoot" Background="#050B14" />
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="{StaticResource EntryMutedBrush}"
                       Text="就绪" />
            <Button Grid.Column="1"
                    Content="关闭"
                    Style="{StaticResource EntryButtonStyle}"
                    Margin="0"
                    Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>
