<Window x:Class="CrossETF.Terminal.UiShell.Reference.Views.RiskCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="风险中心 / 预警日志"
        Width="1180"
        Height="720"
        MinWidth="920"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#050B14"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/RiskCenterActionButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="RiskTextBrush" Color="#EAF6FF" />
        <SolidColorBrush x:Key="RiskMutedBrush" Color="#9FB7C8" />
        <SolidColorBrush x:Key="RiskBackgroundBrush" Color="#050B14" />
        <SolidColorBrush x:Key="RiskPanelBrush" Color="#071B2A" />
        <SolidColorBrush x:Key="RiskHeaderBrush" Color="#0B2B42" />
        <SolidColorBrush x:Key="RiskBorderBrush" Color="#1F4E68" />
        <SolidColorBrush x:Key="RiskHoverBrush" Color="#0E334B" />
        <SolidColorBrush x:Key="RiskSelectedBrush" Color="#123E5A" />
        <SolidColorBrush x:Key="RiskScrollBarBackgroundBrush" Color="#071724" />
        <SolidColorBrush x:Key="RiskScrollBarTrackBrush" Color="#0B2233" />
        <SolidColorBrush x:Key="RiskScrollBarThumbBrush" Color="#2A6688" />
        <SolidColorBrush x:Key="RiskScrollBarThumbHoverBrush" Color="#3D88B0" />
        <SolidColorBrush x:Key="RiskScrollBarThumbPressedBrush" Color="#52A8D0" />
        <SolidColorBrush x:Key="RiskScrollBarArrowBrush" Color="#CFEFFF" />

        <Style x:Key="RiskCenterTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
            <Setter Property="Background" Value="{StaticResource RiskHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RiskBorderBrush}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource RiskHoverBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource RiskSelectedBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#3D88B0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
        </Style>

        <Style x:Key="RiskScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{StaticResource RiskScrollBarArrowBrush}" />
            <Setter Property="Background" Value="{StaticResource RiskScrollBarTrackBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RiskBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource RiskHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource RiskSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RiskScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="{StaticResource RiskScrollBarTrackBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RiskScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{StaticResource RiskScrollBarThumbBrush}" />
            <Setter Property="BorderBrush" Value="#2A6F93" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource RiskScrollBarThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource RiskScrollBarThumbPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="{StaticResource RiskPanelBrush}" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource RiskScrollBarBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource RiskScrollBarArrowBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RiskBorderBrush}" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="VerticalRoot"
                              Width="{TemplateBinding Width}"
                              Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="18" />
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0"
                                          Content="▲"
                                          FontSize="8"
                                          Style="{StaticResource RiskScrollBarButtonStyle}"
                                          Command="{x:Static ScrollBar.LineUpCommand}"
                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                            <Border Grid.Row="1"
                                    Background="{StaticResource RiskScrollBarTrackBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1,0">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource RiskScrollBarPageButtonStyle}"
                                                      Command="{x:Static ScrollBar.PageUpCommand}"
                                                      CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Margin="2"
                                               MinHeight="26"
                                               Style="{StaticResource RiskScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource RiskScrollBarPageButtonStyle}"
                                                      Command="{x:Static ScrollBar.PageDownCommand}"
                                                      CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                            <RepeatButton Grid.Row="2"
                                          Content="▼"
                                          FontSize="8"
                                          Style="{StaticResource RiskScrollBarButtonStyle}"
                                          Command="{x:Static ScrollBar.LineDownCommand}"
                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Height="{TemplateBinding Height}"
                                      Background="{TemplateBinding Background}"
                                      SnapsToDevicePixels="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton Grid.Column="0"
                                                  Content="◀"
                                                  FontSize="8"
                                                  Style="{StaticResource RiskScrollBarButtonStyle}"
                                                  Command="{x:Static ScrollBar.LineLeftCommand}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                                    <Border Grid.Column="1"
                                            Background="{StaticResource RiskScrollBarTrackBrush}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="0,1">
                                        <Track x:Name="PART_Track">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource RiskScrollBarPageButtonStyle}"
                                                              Command="{x:Static ScrollBar.PageLeftCommand}"
                                                              CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Margin="2"
                                                       MinWidth="26"
                                                       Style="{StaticResource RiskScrollBarThumbStyle}" />
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource RiskScrollBarPageButtonStyle}"
                                                              Command="{x:Static ScrollBar.PageRightCommand}"
                                                              CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Border>
                                    <RepeatButton Grid.Column="2"
                                                  Content="▶"
                                                  FontSize="8"
                                                  Style="{StaticResource RiskScrollBarButtonStyle}"
                                                  Command="{x:Static ScrollBar.LineRightCommand}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource RiskPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RiskBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#15384F" />
            <Setter Property="VerticalGridLinesBrush" Value="#15384F" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#071B2A" />
            <Setter Property="AlternatingRowBackground" Value="#082235" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource RiskHeaderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RiskBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#12384F" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RiskSelectedBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RiskHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RiskSelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

            <Style TargetType="Button">
            <Setter Property="Background" Value="#0B2B42" />
            <Setter Property="Foreground" Value="{StaticResource RiskTextBrush}" />
            <Setter Property="BorderBrush" Value="#2A6F93" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,7" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Cursor" Value="Hand" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18" Background="#050B14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="风险中心 / 预警日志" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="只读展示历史预警事件，不代表当前数据源实时状态；不会触发微信、语音或交易动作。"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{StaticResource RiskMutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">
                <Button Content="刷新日志"
                        Style="{StaticResource RiskCenterActionButtonStyle}"
                        Click="RefreshLogsButton_Click" />
                <Button Content="清空日志"
                        Margin="12,0,0,0"
                        Style="{StaticResource RiskCenterDangerButtonStyle}"
                        Click="ClearLogsButton_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource RiskPanelBrush}"
                BorderBrush="{StaticResource RiskBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <TextBlock x:Name="EmptyText"
                           Text="暂无预警日志"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource RiskMutedBrush}" />
                <DataGrid x:Name="AlertLogGrid"
                          Visibility="Collapsed"
                          Margin="1"
                          ItemsSource="{Binding Rows}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt}" Width="145" />
                        <DataGridTextColumn Header="类型" Binding="{Binding AlertType}" Width="110" />
                        <DataGridTextColumn Header="级别" Binding="{Binding Severity}" Width="80" />
                        <DataGridTextColumn Header="标的" Binding="{Binding Target}" Width="110" />
                        <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="*" MinWidth="240" />
                        <DataGridTextColumn Header="微信发送" Binding="{Binding WechatStatus}" Width="100" />
                        <DataGridTextColumn Header="语音播报" Binding="{Binding VoiceStatus}" Width="100" />
                        <DataGridTextColumn Header="错误信息" Binding="{Binding Error}" Width="180" />
                        <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <TextBlock x:Name="StatusText"
                       Text=""
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{StaticResource RiskMutedBrush}" />
        </Grid>
    </Grid>
</Window>
